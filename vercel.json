{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/chat", "dest": "app.py" },
    { "src": "/webhook", "dest": "app.py" },
    { "src": "/health", "dest": "app.py" },
    { "src": "/(.*)", "dest": "index.html" }
  ]
}
